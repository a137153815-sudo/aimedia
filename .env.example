# Shared frontend variables
VITE_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# Frontend only: when deploying frontend and backend separately,
# point this at your standalone backend origin, for example:
# https://aimedia-backend-production.up.railway.app
VITE_API_BASE_URL=""

# Backend only
GEMINI_API_KEY="YOUR_SERVER_SIDE_GEMINI_KEY"
API_KEY="YOUR_SERVER_SIDE_PLATFORM_KEY_OPTIONAL"
ALLOWED_ORIGINS="https://your-frontend-domain.vercel.app,http://localhost:3000"
NODE_ENV="production"
